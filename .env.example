# Aplicação
APP_NAME=helpdesk-system
SERVER_PORT=8080
SPRING_PROFILE=dev

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=helpdesk
DB_USER=helpdesk
DB_PASSWORD=change-me

# JWT
JWT_SECRET=change-me-use-a-long-random-string-with-at-least-256-bits
JWT_EXPIRATION=86400000

# Email
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=user@example.com
MAIL_PASSWORD=change-me
MAIL_FROM=no-reply@example.com

# Administrador inicial (seed no arranque)
ADMIN_EMAIL=admin@helpdesk.com
ADMIN_SENHA=change-me-strong-password

# CORS (origens separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Rate limiting de login
LOGIN_MAX_ATTEMPTS=5
LOGIN_BLOCK_MINUTES=15
